{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "heka-ai-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "vars": {
    "OPENAI_MODEL": "gpt-4.1-mini",
    "GROQ_MODEL": "openai/gpt-oss-120b"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
